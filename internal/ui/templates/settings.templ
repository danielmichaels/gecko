package templates

import (
	"encoding/json"
	"fmt"
)

templ SettingsPage(props SettingsPageProps) {
	@Page("gecko · Settings") {
		@AppShell(props.Shell) {
			<div data-signals={ settingsSignals(props.DefaultScanFrequency) }>
				<div class="page-head">
					<div>
						<h1>Settings</h1>
						<div class="sub">{ props.Shell.UserEmail } · API keys &amp; account</div>
					</div>
				</div>
				<div class="set-grid">
					@APIKeysPanel(props)
					@PasswordPanel(props)
					@ScanningPanel(props)
				</div>
			</div>
		}
	}
}

// APIKeysPanel renders the API-key management section: the one-time secret
// reveal slot, the create form (owner/manager only), and the key list.
templ APIKeysPanel(props SettingsPageProps) {
	<section class="panel set-panel">
		<div class="panel-h">
			API Keys
			<span class="count">{ apiKeyCountLabel(len(props.APIKeys)) }</span>
		</div>
		<div class="set-body">
			<p class="set-note">
				API keys authenticate programmatic and CLI access. A key's secret is shown once at creation and stored only as a hash — if you lose it, revoke the key and mint a new one.
			</p>
			<div id="apikey-secret"></div>
			if props.CanManage {
				<div class="set-create">
					<input
						class="inp"
						placeholder="Key name, e.g. ci-pipeline"
						data-bind="newKeyName"
					/>
					<button
						class="btn"
						type="button"
						data-on:click={ postWithCSRF("/app/settings/apikeys", props.Shell.CSRFToken) }
					>+ Create key</button>
				</div>
			}
			<div id="apikey-rows">
				@APIKeyRows(props.APIKeys, props.Shell.CSRFToken, props.CanManage)
			</div>
		</div>
	</section>
}

// APIKeyRows renders the inner content of #apikey-rows: every key, or an
// empty-state line. Shared by the full page and the create SSE patch.
templ APIKeyRows(keys []APIKeyRowView, csrfToken string, canManage bool) {
	if len(keys) == 0 {
		<div class="set-empty">No API keys yet.</div>
	} else {
		for _, k := range keys {
			@APIKeyRow(k, csrfToken, canManage)
		}
	}
}

// APIKeyRow renders one API key. A revoked key is dimmed and its revoke control
// is removed; an active key shows a revoke button to owner/manager callers.
templ APIKeyRow(k APIKeyRowView, csrfToken string, canManage bool) {
	<div class={ "set-key", templ.KV("revoked", k.Revoked) } id={ "apikey-row-" + k.UID }>
		<div class="set-key-main">
			<span class="set-key-name">{ k.Name }</span>
			<code class="set-key-prefix cell-mono">{ k.Prefix }</code>
			if k.Revoked {
				<span class="badge crit">revoked</span>
			} else {
				<span class="badge ok">active</span>
			}
		</div>
		<div class="set-key-meta cell-mono">
			<span>created { k.Created }</span>
			<span>used { k.LastUsed }</span>
			<span>expires { k.Expires }</span>
		</div>
		<div class="set-key-act">
			if canManage && !k.Revoked {
				<button
					type="button"
					class="btn-ghost btn set-revoke"
					data-on:click={ revokeKey(k.UID, k.Name, csrfToken) }
				>Revoke</button>
			}
		</div>
	</div>
}

// APIKeySecret renders the one-time plaintext reveal after a key is created. The
// secret lives only in this DOM node; the copy button reads it by id and the
// dismiss button clears the container.
templ APIKeySecret(view APIKeySecretView) {
	<div class="set-secret">
		<div class="set-secret-h">
			<span class="badge warn">shown once</span>
			<span>Copy <b>{ view.Name }</b> now — you won't see it again.</span>
			<button
				type="button"
				class="set-secret-x"
				data-on:click="document.getElementById('apikey-secret').replaceChildren()"
			>✕</button>
		</div>
		<div class="set-secret-row">
			<code id="apikey-secret-value" class="set-secret-key cell-mono">{ view.Raw }</code>
			<button
				type="button"
				class="btn"
				data-on:click="navigator.clipboard.writeText(document.getElementById('apikey-secret-value').textContent)"
			>Copy</button>
		</div>
	</div>
}

// PasswordPanel renders the change-password section. The new/confirm match is
// checked client-side as an advisory guard; the server re-verifies the current
// password and length before persisting.
templ PasswordPanel(props SettingsPageProps) {
	<section class="panel set-panel">
		<div class="panel-h">Password</div>
		<div class="set-body">
			<p class="set-note">Changing your password does not revoke existing API keys.</p>
			<label class="lbl">Current password</label>
			<input class="inp" type="password" placeholder="••••••••" data-bind="currentPassword"/>
			<label class="lbl">New password</label>
			<input class="inp" type="password" placeholder="At least 8 characters" data-bind="newPassword"/>
			<label class="lbl">Confirm new password</label>
			<input class="inp" type="password" placeholder="Repeat new password" data-bind="confirmPassword"/>
			<button
				class="btn set-pw-btn"
				type="button"
				data-on:click={ changePassword(props.Shell.CSRFToken) }
			>Update password</button>
		</div>
	</section>
}

// ScanningPanel renders the tenant-wide default scan cadence control.
templ ScanningPanel(props SettingsPageProps) {
	<section class="panel set-panel">
		<div class="panel-h">Scanning</div>
		<div class="set-body">
			<p class="set-note">
				Set how often gecko automatically re-scans all tracked domains. Each domain can override this default individually.
			</p>
			<label class="lbl">Default cadence</label>
			<select class="inp" data-bind="defaultScanFrequency">
				<option value="hourly">Hourly</option>
				<option value="six_hourly">Every 6h</option>
				<option value="daily">Daily</option>
				<option value="weekly">Weekly</option>
				<option value="off">Off</option>
			</select>
			if props.CanManage {
				<button
					class="btn set-pw-btn"
					type="button"
					data-on:click={ postWithCSRF("/app/settings/scan-frequency", props.Shell.CSRFToken) }
				>Save cadence</button>
			}
		</div>
	</section>
}

// apiKeyCountLabel renders the panel-header count, singularising for one key.
func apiKeyCountLabel(n int) string {
	if n == 1 {
		return "1 key"
	}
	return fmt.Sprintf("%d keys", n)
}

// revokeKey returns the data-on:click action that confirms, then DELETEs the key.
// The key name is user-supplied free text, so every interpolated value is
// JSON-encoded into a JS string literal: HTML escaping alone does not protect a
// JavaScript-attribute context (the DOM reverses it before datastar evaluates the
// expression), so a name containing quotes could otherwise break out and inject.
func revokeKey(uid, name, token string) string {
	nameJSON, _ := json.Marshal(name)
	uidJSON, _ := json.Marshal(uid)
	tokenJSON, _ := json.Marshal(token)
	return fmt.Sprintf(
		"if(!confirm('Revoke '+%s+'? Anything using this key stops working immediately.')) return; @delete('/app/settings/apikeys/'+%s, {headers: {'X-CSRF-Token': %s}})",
		nameJSON, uidJSON, tokenJSON,
	)
}

// changePassword returns the data-on:click action that guards the new/confirm
// match client-side, then POSTs the change.
func changePassword(token string) string {
	return fmt.Sprintf(
		"if($newPassword !== $confirmPassword){alert('New passwords do not match');return} @post('/app/settings/password', {headers: {'X-CSRF-Token': '%s'}})",
		token,
	)
}

// settingsSignals builds the page-level datastar signal object for the settings
// page. The defaultScanFrequency signal is pre-filled with the tenant's current
// default so the select renders with the right option pre-selected.
func settingsSignals(defaultScanFreq string) string {
	if defaultScanFreq == "" {
		defaultScanFreq = "daily"
	}
	return fmt.Sprintf(
		`{"newKeyName":"","currentPassword":"","newPassword":"","confirmPassword":"","defaultScanFrequency":"%s"}`,
		defaultScanFreq,
	)
}
