# Copy to `.env` and fill in. `.env` is gitignored. Used by compose.yaml for
# both variable interpolation and as each service's env_file. See DEPLOY.md.

# ── Postgres (the db service initialises from these; the app builds DATABASE_URL from them) ──
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=gecko
POSTGRES_USER=gecko
POSTGRES_PASSWORD=CHANGE_ME            # openssl rand -hex 24
POSTGRES_SSL_MODE=disable              # internal compose network; 'require' if your PG enforces TLS
POSTGRES_MAX_CONNS=16

# ── Security — MUST set (the in-code defaults are unsafe for production) ──
X_API_KEY=CHANGE_ME                    # openssl rand -hex 32  (API auth header)
AUTH_CSRF_SECRET=CHANGE_ME             # openssl rand -hex 32  (browser CSRF protection)
AUTH_SESSION_COOKIE_SECURE=true        # keep true; requires HTTPS at your reverse proxy

# ── App ──
API_SERVER_PORT=9090
APP_PUBLIC_URL=https://gecko.example.com   # used in invite / password-reset links
SIGNUP_ENABLED=false                   # set true only if you want open self-signup
LOG_LEVEL=info

# ── DNS scanning (the worker must have egress to UDP/53; zone transfers use TCP/53) ──
DNS_SERVERS=8.8.8.8:53;1.1.1.1:53;9.9.9.9:53

# ── Mail (optional; 'log' just writes invite/reset tokens to the worker log) ──
MAIL_DRIVER=log
# MAIL_DRIVER=smtp
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# MAIL_FROM=noreply@gecko.example.com

# ── Compose ──
COMPOSE_PROFILES=prod                  # makes `docker compose up -d` run the full stack
# GECKO_IMAGE=ghcr.io/danielmichaels/gecko:v1.2.3   # pin a release instead of :latest
# GECKO_HTTP_PORT=9090                              # host port for serve
# RIVERUI_PORT=8080                                 # host port (localhost) for riverui
